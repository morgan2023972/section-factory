<section class="section-{{ section.id }}">
  <div class="hero" style="background-image: url('{{ section.settings.background_image | img_url: 'master' }}');">
    <div class="hero__content">
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
      {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
        <a href="{{ section.settings.cta_link }}" class="hero__cta" target="{{ section.settings.cta_target }}">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>
  </div>
  <style>
    .section-{{ section.id }} {
      width: 100%;
      overflow: hidden;
    }
    .section-{{ section.id }} .hero {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 25vh;
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
      padding: 5vh 5vw;
      box-sizing: border-box;
      text-align: center;
      color: {{ section.settings.text_color }};
    }
    .section-{{ section.id }} .hero__content {
      max-width: 90vw;
      width: 100%;
    }
    .section-{{ section.id }} .hero__heading {
      font-size: clamp(1.5rem, 5vw, 2.5rem);
      margin-bottom: 0.5em;
      line-height: 1.2;
    }
    .section-{{ section.id }} .hero__subheading {
      font-size: clamp(1rem, 3vw, 1.25rem);
      margin-bottom: 1.5em;
      line-height: 1.5;
    }
    .section-{{ section.id }} .hero__cta {
      display: inline-block;
      background-color: {{ section.settings.cta_background_color }};
      color: {{ section.settings.cta_text_color }};
      padding: 0.75em 1.75em;
      font-weight: 600;
      border-radius: 4px;
      text-decoration: none;
      transition: background-color 0.3s ease;
    }
    .section-{{ section.id }} .hero__cta:hover,
    .section-{{ section.id }} .hero__cta:focus {
      background-color: {{ section.settings.cta_hover_background_color }};
      color: {{ section.settings.cta_hover_text_color }};
    }
    @media (max-width: 749px) {
      .section-{{ section.id }} .hero {
        min-height: 30vh;
        padding: 3vh 4vw;
      }
      .section-{{ section.id }} .hero__heading {
        font-size: clamp(1.25rem, 6vw, 1.75rem);
      }
      .section-{{ section.id }} .hero__subheading {
        font-size: clamp(0.85rem, 4vw, 1rem);
      }
    }
  </style>
  <script>
    (function() {
      const root = document.currentScript?.closest('.section-{{ section.id }}');
      if (!root) return;
      // No dynamic JS needed currently, placeholder for future enhancements.
    })();
  </script>

  {% schema %}
  {
    "name": "Custom Hero",
    "settings": [
      {
        "type": "image_picker",
        "id": "background_image",
        "label": "Background Image",
        "default": "shopify:\/\/shop_images\/default-hero.jpg"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Welcome to Our Store"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading",
        "default": "Find the best products curated just for you."
      },
      {
        "type": "text",
        "id": "cta_text",
        "label": "CTA Button Text",
        "default": "Shop Now"
      },
      {
        "type": "url",
        "id": "cta_link",
        "label": "CTA Button Link",
        "default": "/collections/all"
      },
      {
        "type": "select",
        "id": "cta_target",
        "label": "CTA Link Target",
        "default": "_self",
        "options": [
          { "value": "_self", "label": "Same tab" },
          { "value": "_blank", "label": "New tab" }
        ]
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "cta_background_color",
        "label": "CTA Background Color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "cta_text_color",
        "label": "CTA Text Color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "cta_hover_background_color",
        "label": "CTA Hover Background Color",
        "default": "#333333"
      },
      {
        "type": "color",
        "id": "cta_hover_text_color",
        "label": "CTA Hover Text Color",
        "default": "#ffffff"
      }
    ],
    "blocks": [],
    "presets": [
      {
        "name": "Hero with background image and CTA",
        "category": "Hero"
      }
    ]
  }
  {% endschema %}
</section>