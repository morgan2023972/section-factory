# Keep automatic text normalization as a safe default.
* text=auto

# Enforce LF on structured/text files shared across OSes.
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.sh text eol=lf

# Keep Windows-native script endings.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf