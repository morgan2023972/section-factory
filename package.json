{
  "name": "section-factory",
  "version": "1.0.0",
  "description": "AI-powered Shopify section generator",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "list-sections": "tsx src/index.ts --list-sections",
    "generate": "tsx src/cli/generateSection.ts",
    "validate": "tsx src/cli/validateSection.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^4.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
